{
  "manifest_version": 3,
  "name": "Memoir Clipper",
  "version": "1.0.0",
  "description": "Clip anything from the web or dump your random thoughts!",
  "icons": {
    "16": "public/icons/ic-memoir-16.png",
    "32": "public/icons/ic-memoir-32.png",
    "128": "public/icons/ic-memoir-192.png"
  },
  "permissions": ["storage", "activeTab", "contextMenus"],
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "action": {
    "default_popup": "src/popup/index.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/index.ts"]
    }
  ],
  "options_page": "src/options/index.html",
  "web_accessible_resources": [
    {
      "resources": ["src/styles/tailwind.css"],
      "matches": ["<all_urls>"]
    }
  ]
}
