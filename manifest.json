{
    "manifest_version": 3,
    "name": "Memoir Clipper",
    "version": "1.0.0",
    "description": "A Chrome extension built with TypeScript, Tailwind CSS and Vite",
    "permissions": ["storage", "activeTab"],
    "background": {
        "service_worker": "src/background/index.ts",
        "type": "module"
    },
    "action": {
        "default_popup": "src/popup/index.html"
    },
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["src/content/index.ts"]
        }
    ],
    "options_page": "src/options/index.html"
}
